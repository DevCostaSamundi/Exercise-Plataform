# backend/Dockerfile.dev - Dev image with nodemon (Debian-based to be Prisma-compatible)
FROM node:18-bullseye

WORKDIR /usr/src/app

# Copy package files first for faster rebuilds
COPY package*.json ./

# Install dependencies
RUN npm ci

# Install nodemon globally for convenience
RUN npm install -g nodemon

# Copy prisma dir first to allow prisma generate during build (optional)
COPY prisma ./prisma

# Copy rest of code (in compose we mount ./backend as volume for dev)
COPY . .

ENV NODE_ENV=development
ENV PORT=5000

EXPOSE 5000

CMD ["nodemon", "--watch", ".", "--ext", "js,mjs,json", "server.js"]