# ============================================
# LAUNCHPAD 2.0 - ENVIRONMENT CONFIGURATION
# ============================================
# Copy this file to .env and fill in your values

# ============================================
# SERVER CONFIGURATION
# ============================================
NODE_ENV=development
PORT=5000
API_VERSION=v1

# ============================================
# DATABASE (PostgreSQL)
# ============================================
DATABASE_URL="postgresql://exercise_user:Adult149databaseMande@localhost:5432/exercise_platform?schema=public"

# ============================================
# JWT AUTHENTICATION
# ============================================
# Generate with: openssl rand -hex 64
JWT_SECRET=your_jwt_secret_here_64_chars_minimum_for_security
JWT_EXPIRE=7d
JWT_REFRESH_SECRET=your_refresh_secret_here_64_chars_minimum
JWT_REFRESH_EXPIRE=30d

# ============================================
# URLS
# ============================================
FRONTEND_URL=http://localhost:5173
API_URL=http://localhost:5000
CLIENT_URL=http://localhost:5173

# ============================================
# BASE SEPOLIA NETWORK (Testnet)
# ============================================
# Get free RPC from: https://www.alchemy.com/ or https://www.infura.io/

# RPC Provider
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
# Or with Alchemy (recommended for production):
# BASE_SEPOLIA_RPC_URL=https://base-sepolia.g.alchemy.com/v2/YOUR_ALCHEMY_KEY

# Chain ID
CHAIN_ID=84532

# Block Explorer
BLOCK_EXPLORER_URL=https://sepolia.basescan.org

# ============================================
# SMART CONTRACT ADDRESSES (Base Sepolia)
# ============================================
# TODO: Fill these after deploying contracts with:
# cd contracts && npx hardhat run scripts/deploy-core.js --network baseSepolia

TOKEN_FACTORY_ADDRESS=0x0000000000000000000000000000000000000000
BONDING_CURVE_ADDRESS=0x0000000000000000000000000000000000000000
LIQUIDITY_LOCKER_ADDRESS=0x0000000000000000000000000000000000000000
YIELD_DISTRIBUTOR_ADDRESS=0x0000000000000000000000000000000000000000
CREATOR_REGISTRY_ADDRESS=0x0000000000000000000000000000000000000000
FEE_COLLECTOR_ADDRESS=0x0000000000000000000000000000000000000000

# Platform fee receiver wallet
PLATFORM_WALLET_ADDRESS=0x0000000000000000000000000000000000000000

# ============================================
# CONTRACT DEPLOYMENT
# ============================================
# Private key for deploying contracts (WITHOUT 0x prefix)
# ⚠️ NEVER commit this! Use a dedicated deployment wallet
DEPLOYER_PRIVATE_KEY=your_private_key_here

# BaseScan API Key (for contract verification)
# Get from: https://basescan.org/myapikey
BASESCAN_API_KEY=your_basescan_api_key

# ============================================
# BLOCKCHAIN SYNC
# ============================================
# Start syncing from this block (set to deployment block)
SYNC_START_BLOCK=0

# Polling interval in milliseconds
BLOCK_POLLING_INTERVAL=5000

# Required confirmations for transactions
CONFIRMATIONS_REQUIRED=2

# ============================================
# OPENAI (AI Marketing - Optional)
# ============================================
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# ============================================
# WEB3AUTH (Optional - Social Login)
# ============================================
# Get from: https://dashboard.web3auth.io/
WEB3AUTH_CLIENT_ID=
WEB3AUTH_VERIFIER_NAME=launchpad-google
WEB3AUTH_NETWORK=sapphire_devnet

# ============================================
# SECURITY
# ============================================
# Rate Limiting (15 minutes window)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# CORS
CORS_ORIGIN=http://localhost:5173

# ============================================
# LOGGING
# ============================================
LOG_LEVEL=info
LOG_FILE=logs/app.log

# ============================================
# FEATURE FLAGS
# ============================================
ENABLE_WEB3AUTH=false
ENABLE_METAMASK=true
ENABLE_EMAIL_LOGIN=true
ENABLE_AI_MARKETING=false
