# Application
NODE_ENV=development
PORT=3000
API_PREFIX=api/v1

# Database
DATABASE_URL="postgresql://prideconnect:prideconnect123@localhost:5432/prideconnect?schema=public"

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT
JWT_SECRET=your-super-secret-key-change-in-production-min-32-characters
JWT_EXPIRATION=15m
JWT_REFRESH_SECRET=your-refresh-secret-key-different-from-access-min-32-chars
JWT_REFRESH_EXPIRATION=7d

# Bcrypt
BCRYPT_ROUNDS=12

# Rate Limiting
THROTTLE_TTL=60
THROTTLE_LIMIT=10

# CORS
CORS_ORIGIN=http://localhost:5173

# File Upload
MAX_FILE_SIZE=104857600
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/webp,video/mp4,video/quicktime,audio/mpeg

# AWS S3 / CloudFlare R2
S3_BUCKET=prideconnect-content
S3_REGION=us-east-1
S3_ENDPOINT=
S3_ACCESS_KEY=
S3_SECRET_KEY=

# PIX Payment
PIX_PROVIDER=mercadopago
PIX_API_KEY=
PIX_WEBHOOK_SECRET=

# Email
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@prideconnect.com

# KYC Provider
KYC_PROVIDER=jumio
KYC_API_KEY=
KYC_API_SECRET=
