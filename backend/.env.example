# ============================================
# SERVER CONFIGURATION
# ============================================
NODE_ENV=development
PORT=5000
API_VERSION=v1

# ============================================
# DATABASE
# ============================================
DATABASE_URL="postgresql://exercise_user:Adult149databaseMande@localhost:5432/exercise_platform?schema=public"

# ============================================
# JWT
# ============================================
JWT_SECRET="$(openssl rand -hex 64)"
JWT_EXPIRE=7d
JWT_REFRESH_SECRET="$(openssl rand -hex 64)"
JWT_REFRESH_EXPIRE=30d

# ============================================
# CLOUDINARY (File Uploads)
# ============================================
CLOUDINARY_CLOUD_NAME=dc9hig8yw
CLOUDINARY_API_KEY=282651862392915
CLOUDINARY_API_SECRET=jZRB5M-V1kjUVzybJY8FPvDUNEE

# ============================================
# EMAIL
# ============================================
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=devcostasamundi@gmail.com
EMAIL_PASSWORD=your_app_password_here
EMAIL_FROM=noreply@prideconnect.com

# ============================================
# URLS
# ============================================
FRONTEND_URL=http://localhost:5173
API_URL=http://localhost:5000
WEBHOOK_URL=http://localhost:5000/api/v1
SUCCESS_URL=http://localhost:5173/payment/success
CANCEL_URL=http://localhost:5173/payment/cancel

# ============================================
# WEB3 - BLOCKCHAIN
# ============================================

# RPC Providers (Get free from Alchemy)
POLYGON_RPC_URL=https://polygon-mainnet.g.alchemy.com/v2/YOUR_ALCHEMY_KEY
POLYGON_AMOY_RPC_URL=https://polygon-amoy.g.alchemy.com/v2/YOUR_ALCHEMY_KEY

# Smart Contract Addresses
PAYMENT_CONTRACT_ADDRESS=0x...DeployedContractAddress...
PLATFORM_WALLET_ADDRESS=0x...YourPlatformWallet...

# USDC Contract Addresses
USDC_ADDRESS_POLYGON=0x2791Bca1f2de4661ED88A30C99A7a9449Aa84174
USDC_ADDRESS_AMOY=0x41E94Eb019C0762f9Bfcf9Fb1E58725BfB0e7582

# Contract Deployment
DEPLOYER_PRIVATE_KEY=your_private_key_here
POLYGONSCAN_API_KEY=your_polygonscan_api_key

# ============================================
# WEB3AUTH (Social Login → Invisible Wallet)
# ============================================

# Get from: https://dashboard.web3auth.io/
WEB3AUTH_CLIENT_ID=your_web3auth_client_id
WEB3AUTH_VERIFIER_NAME=prideconnect-google
WEB3AUTH_NETWORK=sapphire_mainnet  # or cyan for testnet

# Optional: Custom Auth (if you want custom JWT)
WEB3AUTH_CLIENT_SECRET=your_client_secret

# ============================================
# ALCHEMY (Blockchain Monitoring)
# ============================================

# Alchemy App ID (same as in RPC URL)
ALCHEMY_API_KEY=YOUR_ALCHEMY_KEY
ALCHEMY_WEBHOOK_ID=wh_...
ALCHEMY_SIGNING_KEY=your_signing_key

# ============================================
# PAYMENT SETTINGS
# ============================================

# Amounts
MIN_PAYMENT_AMOUNT=1
MAX_PAYMENT_AMOUNT=10000
PAYMENT_EXPIRATION_MINUTES=30

# Fees
PLATFORM_FEE_PERCENT=10
GAS_BUFFER_PERCENT=20

# Blockchain
CONFIRMATIONS_REQUIRED=2
BLOCK_POLLING_INTERVAL=5000

# ============================================
# GASLESS TRANSACTIONS (Optional - Future)
# ============================================

# Biconomy/Gelato for gasless txs
ENABLE_GASLESS=false
BICONOMY_API_KEY=
PAYMASTER_URL=

# ============================================
# SECURITY
# ============================================

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# CORS
CORS_ORIGIN=http://localhost:5173

# ============================================
# FILE UPLOAD
# ============================================
MAX_FILE_SIZE=10485760
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/gif,video/mp4,video/quicktime

# ============================================
# LOGGING
# ============================================
LOG_LEVEL=info
LOG_FILE=logs/app.log

# ============================================
# FEATURE FLAGS
# ============================================
ENABLE_WEB3AUTH=true
ENABLE_WALLET_CONNECT=false
ENABLE_METAMASK=true
ENABLE_EMAIL_LOGIN=true