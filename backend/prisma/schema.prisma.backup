// Prisma Schema for Launchpad 2.0
// Migrated from PrideConnect - Focus on Token Launchpad

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// User model - Base user account
model User {
  id            String    @id @default(uuid())
  email         String    @unique
  username      String    @unique
  password      String
  firstName     String? 
  lastName      String?
  displayName   String?
  birthDate     DateTime?
  genderIdentity String?
  orientation   String?
  avatar        String?
  bio           String?
  isVerified    Boolean   @default(false)
  isActive      Boolean   @default(true)
  role          UserRole  @default(USER)
  
  // Web3 fields
  web3Wallet    String?   @unique
  web3Provider  String?   // 'web3auth', 'metamask', 'walletconnect', 'coinbase', 'trustwallet', 'binance', 'okx', 'ledger', 'trezor', 'phantom', 'solflare', 'brave', 'opera', 'edge', 'firefox', 'chrome', 'safari', 'other'
  web3Verified  Boolean   @default(false)
  web3VerifiedAt DateTime?

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  payments      Payment[] @relation("UserPayments")
  wallet        UserWallet? 

  
  // Relations originais
  creator       Creator?  
  subscriptions Subscription[]
  orders        Order[]
  reviews       Review[]
  
  // Relações de mensagens
  creatorConversations     Conversation[] @relation("CreatorConversations")
  subscriberConversations  Conversation[] @relation("SubscriberConversations")
  sentMessages             Message[]      @relation("SentMessages")
  receivedMessages         Message[]      @relation("ReceivedMessages")
  
  // Relações de comentários e likes
  comments                 Comment[]
  likes                    Like[]

  notifications            Notification[]
  
  // Launchpad relations
  createdTokens            Token[]
  trades                   Trade[]
  tokenHoldings            TokenHolder[]
  yieldClaims              YieldClaim[]
  creatorRatings           CreatorRating[]

  @@index([web3Wallet])  
  @@map("users")
}

enum UserRole {
  USER
  CREATOR
  ADMIN
}

// Creator model - Extended profile for content creators
model Creator {
  id              String    @id @default(uuid())
  userId          String    @unique
  displayName     String
  coverImage      String?
  description     String?
  
  // Verification & KYC
  isVerified      Boolean   @default(false)
  featured        Boolean   @default(false)
  kycStatus       KYCStatus @default(PENDING)
  kycDocuments    Json? 
  
  // Monetization
  subscriptionPrice Decimal @default(0) @db.Decimal(10, 2)
  earnings          Decimal @default(0) @db.Decimal(10, 2)
  
  // Settings fields
  location              String?
  website               String?
  category              String?
  socialLinks           Json?

  postsCount      Int       @default(0)
  
  // Subscription settings
  discounts             Json?           @default("{\"threeMonths\": 10, \"sixMonths\": 15, \"twelveMonths\": 20}")
  promoActive           Boolean         @default(false)
  promoDiscount         Int?
  promoDuration         Int?
  promoExpiry           String?
  trialEnabled          Boolean         @default(false)
  trialDays             Int?
  
  // Payment settings
  withdrawMethod        String          @default("web3")
  
  // Web3 wallet for receiving USDC
  payoutWallet          String?         // Wallet address for USDC payouts
  walletVerified        Boolean         @default(false)
  autoWithdraw          Boolean         @default(false)
  autoWithdrawMin       Int             @default(100)
  
  // Notification settings
  emailNotifications    Json?
  pushNotifications     Json?
  marketingEmails       Boolean         @default(true)
  newsletter            Boolean         @default(true)
  
  // Privacy settings
  publicProfile         Boolean         @default(true)
  showActivity          Boolean         @default(true)
  showSubscriberCount   Boolean         @default(true)
  messagePermission     String          @default("subscribers")
  allowTips             Boolean         @default(true)
  watermark             Boolean         @default(true)
  disableScreenshots    Boolean         @default(false)
  hideFromSearch        Boolean         @default(false)
  blockedCountries      String[]        @default([])
  
  // Content settings
  defaultPPV            Boolean         @default(false)
  autoPublish           Boolean         @default(true)
  commentsEnabled       Boolean         @default(true)
  defaultPPVPrice       Float           @default(9.99)
  imageQuality          String          @default("high")
  videoQuality          String          @default("1080p")
  
  // Blocking
  blockedUsers          String[]        @default([])
  blockedWords          String[]        @default([])
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  // Relations
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  posts           Post[]
  products        Product[]
  subscriptions   Subscription[]

  receivedPayments  Payment[]   @relation("CreatorPayments")
  balance           CreatorBalance? 
  withdrawals       Withdrawal[]
  
  @@map("creators")
}

enum KYCStatus {
  PENDING
  APPROVED
  REJECTED
  RESUBMIT
}

// Post model - Content posts from creators
model Post {
  id          String      @id @default(uuid())
  creatorId   String
  title       String? 
  content     String?
  mediaUrls   Json?       // Array of media URLs
  mediaType   MediaType   @default(IMAGE)
  isPublic    Boolean     @default(false) // false = subscribers only
  isPPV       Boolean     @default(false) // Pay-per-view
  ppvPrice    Decimal?    @db.Decimal(10, 2)
  
  // NOVOS CAMPOS ADICIONADOS
  tags        String[]    @default([])    // Array de tags
  scheduledFor  DateTime?                 // Data de Agendamento
  status      PostStatus  @default(PUBLISHED) // Status do Post

  // Engagement
  likesCount  Int         @default(0)
  commentsCount Int       @default(0)
  viewsCount  Int         @default(0)
  
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  
  // Relations
  creator     Creator     @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  comments    Comment[]
  likes       Like[]
  
  @@map("posts")
}

enum PostStatus {
  DRAFT
  PUBLISHED
  SCHEDULED
  ARCHIVED
}

enum MediaType {
  IMAGE
  VIDEO
  AUDIO
  DOCUMENT
}

// Subscription model - User subscriptions to creators
model Subscription {
  id              String    @id @default(uuid())
  userId          String
  creatorId       String
  
  status          SubscriptionStatus @default(ACTIVE)
  startDate       DateTime  @default(now())
  endDate         DateTime?
  autoRenew       Boolean   @default(true)
  
  // Payment
  amount          Decimal   @db.Decimal(10, 2)
  paymentMethod   String?
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  // Relations
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  creator         Creator   @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  
  @@unique([userId, creatorId])
  @@map("subscriptions")
}

enum SubscriptionStatus {
  ACTIVE
  EXPIRED
  CANCELLED
}

// Product model - Marketplace products
model Product {
  id              String    @id @default(uuid())
  creatorId       String
  
  name            String
  description     String
  category        ProductCategory
  type            ProductType
  
  // Pricing
  price           Decimal   @db.Decimal(10, 2)
  
  // Images
  images          Json?     // Array of image URLs
  
  // Inventory (for physical products)
  stock           Int? 
  isUnlimited     Boolean   @default(false)
  
  // Digital product
  digitalFileUrl  String?
  
  // Status
  isActive        Boolean   @default(true)
  
  // Stats
  soldCount       Int       @default(0)
  viewsCount      Int       @default(0)
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  // Relations
  creator         Creator   @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  orderItems      OrderItem[]
  reviews         Review[]
  
  @@map("products")
}

enum ProductCategory {
  PHYSICAL_ITEM
  DIGITAL_CONTENT
  EXPERIENCE
  MERCHANDISE
  ART
  OTHER
}

enum ProductType {
  PHYSICAL
  DIGITAL
  HYBRID
}

// Order model - Marketplace orders
model Order {
  id              String      @id @default(uuid())
  userId          String
  orderNumber     String      @unique
  
  // Status
  status          OrderStatus @default(PENDING)
  
  // Pricing
  subtotal        Decimal     @db.Decimal(10, 2)
  shippingCost    Decimal     @default(0) @db.Decimal(10, 2)
  tax             Decimal     @default(0) @db.Decimal(10, 2)
  total           Decimal     @db.Decimal(10, 2)
  
  // Payment - ⚠️ RENOMEADO para OrderPaymentStatus
  paymentStatus   OrderPaymentStatus @default(ORDER_PENDING)
  paymentMethod   String?
  transactionId   String?
  
  // Shipping
  shippingAddress Json?
  trackingNumber  String?
  
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  
  // Relations
  user            User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  items           OrderItem[]
  
  @@map("orders")
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
  REFUNDED
}

// ⚠️ ENUM RENOMEADO para evitar conflito com PaymentStatus
enum OrderPaymentStatus {
  ORDER_PENDING
  ORDER_COMPLETED
  ORDER_FAILED
  ORDER_REFUNDED
}

// OrderItem model - Items in an order
model OrderItem {
  id          String    @id @default(uuid())
  orderId     String
  productId   String
  
  quantity    Int       @default(1)
  price       Decimal   @db.Decimal(10, 2)
  
  createdAt   DateTime  @default(now())
  
  // Relations
  order       Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product     Product   @relation(fields: [productId], references: [id])
  
  @@map("order_items")
}

// Review model - Product reviews
model Review {
  id          String    @id @default(uuid())
  userId      String
  productId   String
  
  rating      Int       // 1-5
  comment     String?
  images      Json?     // Array of image URLs
  
  // Moderation
  isApproved  Boolean   @default(false)
  
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  
  // Relations
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  product     Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  
  @@unique([userId, productId])
  @@map("reviews")
}

// ============================================
// SISTEMA DE MENSAGENS
// ============================================

model Conversation {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Participantes
  creatorId    String
  creator      User   @relation("CreatorConversations", fields: [creatorId], references: [id], onDelete: Cascade)
  
  subscriberId String
  subscriber   User   @relation("SubscriberConversations", fields: [subscriberId], references: [id], onDelete: Cascade)

  // Última mensagem
  lastMessageText      String?
  lastMessageSenderId  String?
  lastMessageTimestamp DateTime?

  // Contadores de não lidas
  unreadCountCreator    Int @default(0)
  unreadCountSubscriber Int @default(0)

  // Status
  status String @default("active") // active, archived, blocked
  isVIP  Boolean @default(false)

  // Relações
  messages Message[]

  @@unique([creatorId, subscriberId])
  @@index([creatorId, status])
  @@index([subscriberId, status])
  @@index([lastMessageTimestamp])
  @@map("conversations")
}

model Message {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relação com conversa
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  // Remetente e destinatário
  senderId    String
  sender      User   @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)
  
  recipientId String
  recipient   User   @relation("ReceivedMessages", fields: [recipientId], references: [id], onDelete: Cascade)

  // Tipo e conteúdo
  type String @default("text") // text, image, video, paid

  // Conteúdo
  contentText     String?
  contentMediaUrl String[] // Array de URLs
  contentPrice    Float?
  contentIsPaid   Boolean  @default(false)

  // Status
  status String @default("sent") // sent, delivered, read, failed
  readAt DateTime?

  // Metadados
  metadataIpAddress       String?
  metadataUserAgent       String?
  metadataFlagged         Boolean @default(false)
  metadataModerationAction String?  

  deletedAt DateTime?

  @@index([conversationId, createdAt])
  @@index([senderId, createdAt])
  @@index([status])
  @@map("messages")
}

// ============================================
// SISTEMA DE PAGAMENTOS
// ============================================

model Payment {
  id              String        @id @default(uuid())
  
  // Relacionamentos
  userId          String
  user            User          @relation("UserPayments", fields: [userId], references: [id], onDelete: Cascade)
  
  creatorId       String?  
  creator         Creator?      @relation("CreatorPayments", fields: [creatorId], references: [id])
  
  // Tipo de pagamento
  type            PaymentType
  
  // Referências
  subscriptionId  String?
  postId          String?
  messageId       String?
  
  // Valores em FIAT
  amountUSD       Decimal       @db.Decimal(10, 2)
  amountBRL       Decimal?      @db.Decimal(10, 2)
  currency        String        @default("USD")
  
  // Valores em Cripto
  cryptoCurrency  String?       // BTC, ETH, USDT_TRC20, etc
  cryptoAmount    String?       // Quantidade exata em cripto
  cryptoAddress   String?       // Endereço de recebimento gerado
  expectedAmount  String?       // Quantidade esperada
  actuallyPaid    String?       // Quantidade realmente paga
  
  // Blockchain
  txHash          String?       @unique // Transaction hash
  confirmations   Int           @default(0)
  networkFee      String?       // Taxa de rede paga
  
  // Web3 specific
  web3TxHash         String?   @unique  // On-chain transaction hash
  web3BlockNumber    Int?                // Block number
  web3Confirmations  Int       @default(0)
  web3ContractAddress String?            // Smart contract used
  
  
  // Status
  status          PaymentStatus @default(PENDING)
  
  // Gateway usado
  gateway         PaymentGateway
  gatewayOrderId  String?       @unique // ID externo do gateway
  gatewayData     Json?         // Dados extras do gateway
  
  // Taxas da plataforma
  platformFee     Decimal       @db.Decimal(10, 2) @default(0) // 10%
  gatewayFee      Decimal       @db.Decimal(10, 2) @default(0) // Taxa do gateway
  netAmount       Decimal       @db.Decimal(10, 2) // Valor líquido para o criador
  
  // Timestamps
  paidAt          DateTime?  
  confirmedAt     DateTime?
  expiresAt       DateTime?
  
  // Metadados
  ipAddress       String?
  userAgent       String?
  metadata        Json?
  
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  
  @@index([userId])
  @@index([creatorId])
  @@index([status])
  @@index([gateway])
  @@index([txHash])
  @@index([gatewayOrderId])
  @@index([type])
  @@map("payments")
}

model CreatorBalance {
  id              String        @id @default(uuid())
  creatorId       String        @unique
  creator         Creator       @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  
  // Saldo disponível
  availableUSD    Decimal       @db.Decimal(10, 2) @default(0)
  
  // Saldo pendente (aguardando confirmação)
  pendingUSD      Decimal       @db.Decimal(10, 2) @default(0)
  
  // Total de ganhos
  lifetimeEarnings Decimal      @db.Decimal(10, 2) @default(0)
  
  // Saques
  totalWithdrawn  Decimal       @db.Decimal(10, 2) @default(0)
  
  // Estatísticas
  lastPaymentAt   DateTime?
  lastWithdrawalAt DateTime?
  
  updatedAt       DateTime      @updatedAt
  
  @@map("creator_balances")
}

model Withdrawal {
  id              String           @id @default(uuid())
  creatorId       String
  creator         Creator          @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  
  // Valores
  amountUSD       Decimal          @db.Decimal(10, 2)
  
  // Destino Cripto
  cryptoCurrency  String           // BTC, ETH, USDT_TRC20, etc
  cryptoAmount    String
  destinationAddress String
  
  // Blockchain
  txHash          String?
  networkFee      Decimal?         @db.Decimal(10, 2)
  
  // Status
  status          WithdrawalStatus @default(PENDING)
  
  // Taxas
  platformFee     Decimal          @db.Decimal(10, 2) @default(2) // Taxa fixa $2
  netAmount       Decimal          @db.Decimal(10, 2) // Valor líquido enviado
  
  // Gateway
  gateway         PaymentGateway? 
  gatewayTxId     String? 
  
  // Aprovação (se necessário)
  approvedBy      String?
  approvedAt      DateTime?
  rejectedReason  String? 
  
  // Timestamps
  processedAt     DateTime? 
  completedAt     DateTime? 
  
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  
  @@index([creatorId])
  @@index([status])
  @@map("withdrawals")
}

model UserWallet {
  id              String        @id @default(uuid())
  userId          String        @unique
  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  // Saldo depositado (sistema de carteira interna)
  balanceUSD      Decimal       @db.Decimal(10, 2) @default(0)
  
  // Histórico
  totalDeposited  Decimal       @db.Decimal(10, 2) @default(0)
  totalSpent      Decimal       @db.Decimal(10, 2) @default(0)
  
  // Auto-renovação
  autoRenewEnabled Boolean      @default(false)
  lowBalanceAlert  Boolean      @default(true)
  alertThreshold   Decimal      @db.Decimal(10, 2) @default(20)
  
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  
  @@map("user_wallets")
}

// Enums
enum PaymentType {
  SUBSCRIPTION
  SUBSCRIPTION_RENEWAL
  PPV_MESSAGE
  PPV_POST
  TIP
  WALLET_DEPOSIT
  GIFT
}

enum PaymentStatus {
  PENDING          // Aguardando pagamento
  WAITING          // Pagamento detectado, aguardando confirmações
  CONFIRMING       // Confirmando no blockchain
  COMPLETED        // Confirmado e processado
  FAILED           // Falhou
  EXPIRED          // Expirou (15 min)
  PARTIALLY_PAID   // Pagou menos que o esperado
  REFUNDED         // Reembolsado
  CANCELLED        // Cancelado pelo usuário
}

enum PaymentGateway {
  WEB3_DIRECT      // Direct wallet payment
  CRYPTO_DIRECT    // Direct crypto payment via smart contract
  BALANCE          // Internal wallet balance
  MANUAL           // Manual transfer
}

enum WithdrawalStatus {
  PENDING          // Solicitado
  APPROVED         // Aprovado (se necessário)
  PROCESSING       // Processando
  COMPLETED        // Enviado
  FAILED           // Falhou
  CANCELLED        // Cancelado
  REJECTED         // Rejeitado (fraude)
}

// ============================================
// SISTEMA DE COMENTÁRIOS E LIKES
// ============================================

model Comment {
  id        String   @id @default(uuid())
  postId    String
  userId    String
  content   String
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  // Relations
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([postId])
  @@index([userId])
  @@map("comments")
}

model Like {
  id        String   @id @default(uuid())
  postId    String
  userId    String
  
  createdAt DateTime @default(now())
  
  // Relations
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@unique([postId, userId])
  @@index([postId])
  @@index([userId])
  @@map("likes")
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      NotificationType
  title     String
  message   String
  metadata  Json?    // Dados extras (ex: postId, subscriberId, etc)
  actionUrl String?
  unread    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, unread])
  @@index([userId, createdAt])
  @@map("notifications")
}

enum NotificationType {
  SUBSCRIBER
  COMMENT
  TIP
  LIKE
  MESSAGE
  PAYMENT
  MILESTONE
  SYSTEM
  WARNING
}

// ============================================
// AI MARKETING MODELS
// ============================================

// Marketing strategies generated by AI
model MarketingStrategy {
  id          String   @id @default(uuid())
  type        String   // 'PLATFORM_POST', 'TOKEN_LAUNCH', 'CAMPAIGN'
  content     String   // Generated tweet/post content
  reasoning   String   // AI reasoning for this strategy
  metrics     Json     // Platform metrics at time of generation
  posted      Boolean  @default(false)
  postedAt    DateTime?
  engagement  Json?    // Metrics after posting (likes, shares, etc)
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@index([type])
  @@index([posted])
  @@map("marketing_strategies")
}

// Track platform analytics for AI decision-making
model PlatformAnalytics {
  id              String   @id @default(uuid())
  date            DateTime @default(now())
  
  // Volume metrics
  totalVolume     Decimal  @default(0) @db.Decimal(18, 2)
  volumeChange    Decimal  @default(0) @db.Decimal(5, 2) // Percentage
  
  // Token metrics
  newTokens       Int      @default(0)
  activeTokens    Int      @default(0)
  deadTokens      Int      @default(0)
  
  // User metrics
  totalUsers      Int      @default(0)
  activeUsers     Int      @default(0)
  newUsers        Int      @default(0)
  
  // Trade metrics
  totalTrades     Int      @default(0)
  uniqueTraders   Int      @default(0)
  avgTradesPerUser Decimal @default(0) @db.Decimal(5, 2)
  
  // Engagement
  engagementScore Decimal  @default(0) @db.Decimal(3, 2)
  
  // Additional data
  metadata        Json?    // Top tokens, categories, etc
  
  @@index([date])
  @@map("platform_analytics")
}

// Sentiment tracking from social media
model SentimentData {
  id          String   @id @default(uuid())
  source      String   // 'TWITTER', 'REDDIT', 'TELEGRAM'
  sentiment   String   // 'POSITIVE', 'NEUTRAL', 'NEGATIVE'
  score       Decimal  @db.Decimal(3, 2) // 0-10
  content     String   // Original tweet/post
  author      String?  // Username
  authorFollowers Int? // Influence score
  mentions    Int      @default(1)
  
  createdAt   DateTime @default(now())
  
  @@index([source, createdAt])
  @@index([sentiment])
  @@map("sentiment_data")
}

// Growth tactics and their results
model GrowthTactic {
  id              String   @id @default(uuid())
  name            String
  description     String
  category        String   // 'REFERRAL', 'AIRDROP', 'CONTEST', 'PARTNERSHIP'
  effort          String   // 'EASY', 'MEDIUM', 'HARD'
  cost            Decimal  @db.Decimal(10, 2)
  expectedImpact  String   // 'LOW', 'MEDIUM', 'HIGH'
  
  // Results tracking
  tested          Boolean  @default(false)
  testedAt        DateTime?
  actualImpact    Json?    // Actual metrics after testing
  success         Boolean?
  
  // AI recommendation score
  aiScore         Decimal? @db.Decimal(3, 2)
  aiReasoning     String?
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  @@index([tested])
  @@index([category])
  @@map("growth_tactics")
}

// ============================================
// LAUNCHPAD TOKEN MODELS
// ============================================

// Token created via TokenFactory
model Token {
  id              String    @id @default(uuid())
  address         String    @unique  // On-chain contract address
  name            String
  symbol          String
  totalSupply     String    // BigInt as string
  
  // Creator info
  creatorAddress  String    // Wallet address of creator
  creatorId       String?   // Optional link to User
  creator         User?     @relation(fields: [creatorId], references: [id])
  
  // Metadata
  description     String?
  logo            String?
  website         String?
  twitter         String?
  telegram        String?
  discord         String?
  
  // On-chain metrics (synced from blockchain)
  currentPrice    Decimal   @default(0) @db.Decimal(28, 18)
  marketCap       Decimal   @default(0) @db.Decimal(28, 2)
  totalVolume     Decimal   @default(0) @db.Decimal(28, 2)
  volume24h       Decimal   @default(0) @db.Decimal(28, 2)
  priceChange24h  Decimal   @default(0) @db.Decimal(10, 2) // Percentage
  holderCount     Int       @default(0)
  tradeCount      Int       @default(0)
  
  // Bonding curve status
  bondingCurveAddress String?
  liquidityLocked     Boolean   @default(false)
  lockDuration        Int?      // Days
  lockExpiry          DateTime?
  
  // Graduation status (to DEX)
  isGraduated     Boolean   @default(false)
  graduatedAt     DateTime?
  dexPoolAddress  String?
  
  // Timestamps
  blockNumber     Int?
  txHash          String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  // Relations
  trades          Trade[]
  holders         TokenHolder[]
  yieldClaims     YieldClaim[]
  
  @@index([creatorAddress])
  @@index([isGraduated])
  @@index([createdAt])
  @@index([volume24h])
  @@map("tokens")
}

// Trade events from BondingCurve
model Trade {
  id              String    @id @default(uuid())
  
  // Token reference
  tokenAddress    String
  token           Token     @relation(fields: [tokenAddress], references: [address])
  
  // Trader info
  traderAddress   String
  traderId        String?   // Optional link to User
  trader          User?     @relation(fields: [traderId], references: [id])
  
  // Trade details
  type            TradeType
  ethAmount       Decimal   @db.Decimal(28, 18) // ETH paid/received
  tokenAmount     Decimal   @db.Decimal(28, 18) // Tokens bought/sold
  price           Decimal   @db.Decimal(28, 18) // Price per token at time of trade
  
  // Fees
  platformFee     Decimal   @default(0) @db.Decimal(28, 18)
  creatorFee      Decimal   @default(0) @db.Decimal(28, 18)
  
  // On-chain data
  txHash          String    @unique
  blockNumber     Int
  logIndex        Int
  
  timestamp       DateTime  @default(now())
  
  @@index([tokenAddress])
  @@index([traderAddress])
  @@index([timestamp])
  @@index([type])
  @@map("trades")
}

enum TradeType {
  BUY
  SELL
}

// Token holder balances (synced from blockchain)
model TokenHolder {
  id              String    @id @default(uuid())
  
  // Token reference
  tokenAddress    String
  token           Token     @relation(fields: [tokenAddress], references: [address])
  
  // Holder info
  holderAddress   String
  holderId        String?   // Optional link to User
  holder          User?     @relation(fields: [holderId], references: [id])
  
  // Balance
  balance         Decimal   @db.Decimal(28, 18)
  percentage      Decimal   @default(0) @db.Decimal(10, 4) // Percentage of total supply
  
  // Stats
  firstBuyAt      DateTime?
  lastTradeAt     DateTime?
  totalBought     Decimal   @default(0) @db.Decimal(28, 18)
  totalSold       Decimal   @default(0) @db.Decimal(28, 18)
  realizedPnl     Decimal   @default(0) @db.Decimal(28, 18)
  
  updatedAt       DateTime  @updatedAt
  
  @@unique([tokenAddress, holderAddress])
  @@index([tokenAddress])
  @@index([holderAddress])
  @@index([balance])
  @@map("token_holders")
}

// Yield claims from YieldDistributor
model YieldClaim {
  id              String    @id @default(uuid())
  
  // Token reference
  tokenAddress    String
  token           Token     @relation(fields: [tokenAddress], references: [address])
  
  // Claimer info
  claimerAddress  String
  claimerId       String?   // Optional link to User
  claimer         User?     @relation(fields: [claimerId], references: [id])
  
  // Claim details
  amount          Decimal   @db.Decimal(28, 18) // ETH claimed
  
  // On-chain data
  txHash          String    @unique
  blockNumber     Int
  
  timestamp       DateTime  @default(now())
  
  @@index([tokenAddress])
  @@index([claimerAddress])
  @@index([timestamp])
  @@map("yield_claims")
}

// Creator ratings from CreatorRegistry
model CreatorRating {
  id              String    @id @default(uuid())
  
  // Creator being rated
  creatorAddress  String
  
  // Rater info
  raterAddress    String
  raterId         String?   // Optional link to User
  rater           User?     @relation(fields: [raterId], references: [id])
  
  // Rating
  rating          Int       // 1-5 stars (stored as 100-500 on-chain)
  
  // On-chain data
  txHash          String    @unique
  blockNumber     Int
  
  timestamp       DateTime  @default(now())
  
  @@unique([creatorAddress, raterAddress])
  @@index([creatorAddress])
  @@index([rating])
  @@map("creator_ratings")
}

// Blockchain sync status (for event indexing)
model SyncStatus {
  id              String    @id @default(uuid())
  contractName    String    @unique  // 'TokenFactory', 'BondingCurve', etc
  contractAddress String
  lastSyncedBlock Int       @default(0)
  lastSyncedAt    DateTime?
  isActive        Boolean   @default(true)
  
  @@map("sync_status")
}