// ============================================
// Prisma Schema for Launchpad 2.0
// Clean version - Token Trading Platform on Base
// ============================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// USER & AUTH
// ============================================

model User {
  id            String    @id @default(uuid())
  email         String?   @unique
  username      String    @unique
  password      String?
  displayName   String?
  firstName     String?
  lastName      String?
  birthDate     DateTime?
  avatarUrl     String?   @map("avatar")
  bio           String?
  isVerified    Boolean   @default(false)
  isActive      Boolean   @default(true)
  role          UserRole  @default(USER)
  
  // Password reset
  resetPasswordToken   String?
  resetPasswordExpires DateTime?
  
  // Web3 fields (primary auth)
  web3Wallet    String?   @unique
  web3Provider  String?
  web3Verified  Boolean   @default(false)
  web3VerifiedAt DateTime?

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  // Relations
  wallets       UserWallet[]
  payments      Payment[]
  notifications Notification[]
  
  // Launchpad relations
  createdTokens Token[]        @relation("TokenCreator")
  trades        Trade[]
  tokenHoldings TokenHolder[]
  yieldClaims   YieldClaim[]
  ratingsGiven  CreatorRating[]

  @@index([web3Wallet])  
  @@map("users")
}

enum UserRole {
  USER
  CREATOR
  ADMIN
}

model UserWallet {
  id              String    @id @default(uuid())
  userId          String    
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  walletAddress   String    @unique
  isPrimary       Boolean   @default(false)
  
  balanceUSD      Decimal   @db.Decimal(10, 2) @default(0)
  totalDeposited  Decimal   @db.Decimal(10, 2) @default(0)
  totalSpent      Decimal   @db.Decimal(10, 2) @default(0)
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  @@index([userId])
  @@map("user_wallets")
}

// ============================================
// PAYMENTS
// ============================================

model Payment {
  id              String        @id @default(uuid())
  userId          String
  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  type            PaymentType
  amountUSD       Decimal       @db.Decimal(10, 2)
  amountETH       Decimal?      @db.Decimal(28, 18)
  
  txHash          String?       @unique
  blockNumber     Int?
  confirmations   Int           @default(0)
  status          PaymentStatus @default(PENDING)
  tokenAddress    String?
  metadata        Json?
  
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  
  @@index([userId])
  @@index([status])
  @@index([txHash])
  @@map("payments")
}

enum PaymentType {
  TOKEN_CREATION
  TOKEN_PURCHASE
  TOKEN_SALE
  YIELD_CLAIM
  PLATFORM_FEE
}

enum PaymentStatus {
  PENDING
  CONFIRMING
  COMPLETED
  FAILED
  REFUNDED
}

// ============================================
// NOTIFICATIONS
// ============================================

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  type      NotificationType
  title     String
  message   String
  metadata  Json?
  actionUrl String?
  unread    Boolean  @default(true)
  
  createdAt DateTime @default(now())

  @@index([userId, unread])
  @@index([userId, createdAt])
  @@map("notifications")
}

enum NotificationType {
  TOKEN_CREATED
  TOKEN_GRADUATED
  TRADE_EXECUTED
  YIELD_AVAILABLE
  YIELD_CLAIMED
  PRICE_ALERT
  MILESTONE
  SYSTEM
}

// ============================================
// AI MARKETING (Admin)
// ============================================

model MarketingStrategy {
  id          String   @id @default(uuid())
  type        String
  content     String
  reasoning   String
  metrics     Json
  posted      Boolean  @default(false)
  postedAt    DateTime?
  engagement  Json?
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@index([type])
  @@index([posted])
  @@map("marketing_strategies")
}

model PlatformAnalytics {
  id              String   @id @default(uuid())
  date            DateTime @default(now()) @unique
  
  totalVolume     Decimal  @default(0) @db.Decimal(28, 2)
  volumeChange    Decimal  @default(0) @db.Decimal(5, 2)
  newTokens       Int      @default(0)
  activeTokens    Int      @default(0)
  graduatedTokens Int      @default(0)
  totalUsers      Int      @default(0)
  activeUsers     Int      @default(0)
  newUsers        Int      @default(0)
  totalTrades     Int      @default(0)
  uniqueTraders   Int      @default(0)
  metadata        Json?
  
  @@index([date])
  @@map("platform_analytics")
}

model SentimentData {
  id          String   @id @default(uuid())
  source      String
  sentiment   String
  score       Decimal  @db.Decimal(3, 2)
  content     String
  author      String?
  mentions    Int      @default(1)
  
  createdAt   DateTime @default(now())
  
  @@index([source, createdAt])
  @@map("sentiment_data")
}

model GrowthTactic {
  id              String   @id @default(uuid())
  name            String
  description     String
  category        String
  effort          String
  cost            Decimal  @db.Decimal(10, 2)
  expectedImpact  String
  tested          Boolean  @default(false)
  testedAt        DateTime?
  actualImpact    Json?
  success         Boolean?
  aiScore         Decimal? @db.Decimal(3, 2)
  aiReasoning     String?
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  @@index([category])
  @@map("growth_tactics")
}

// ============================================
// LAUNCHPAD - TOKEN MODELS
// ============================================

model Token {
  id              String    @id @default(uuid())
  address         String    @unique
  name            String
  symbol          String
  totalSupply     String
  
  creatorAddress  String
  creatorId       String?
  creator         User?     @relation("TokenCreator", fields: [creatorId], references: [id])
  
  description     String?
  logo            String?
  website         String?
  twitter         String?
  telegram        String?
  discord         String?
  
  currentPrice    Decimal   @default(0) @db.Decimal(28, 18)
  marketCap       Decimal   @default(0) @db.Decimal(28, 2)
  totalVolume     Decimal   @default(0) @db.Decimal(28, 2)
  volume24h       Decimal   @default(0) @db.Decimal(28, 2)
  priceChange24h  Decimal   @default(0) @db.Decimal(10, 2)
  holderCount     Int       @default(0)
  tradeCount      Int       @default(0)
  
  bondingCurveAddress String?
  liquidityLocked     Boolean   @default(false)
  isGraduated     Boolean   @default(false)
  graduatedAt     DateTime?
  dexPoolAddress  String?
  
  blockNumber     Int?
  txHash          String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  trades          Trade[]
  holders         TokenHolder[]
  yieldClaims     YieldClaim[]
  
  @@index([creatorAddress])
  @@index([isGraduated])
  @@index([volume24h])
  @@index([createdAt])
  @@map("tokens")
}

model Trade {
  id              String    @id @default(uuid())
  
  tokenAddress    String
  token           Token     @relation(fields: [tokenAddress], references: [address])
  
  traderAddress   String
  traderId        String?
  trader          User?     @relation(fields: [traderId], references: [id])
  
  type            TradeType
  ethAmount       Decimal   @db.Decimal(28, 18)
  tokenAmount     Decimal   @db.Decimal(28, 18)
  price           Decimal   @db.Decimal(28, 18)
  platformFee     Decimal   @default(0) @db.Decimal(28, 18)
  creatorFee      Decimal   @default(0) @db.Decimal(28, 18)
  
  txHash          String    @unique
  blockNumber     Int
  logIndex        Int
  timestamp       DateTime  @default(now())
  
  @@index([tokenAddress])
  @@index([traderAddress])
  @@index([timestamp])
  @@map("trades")
}

enum TradeType {
  BUY
  SELL
}

model TokenHolder {
  id              String    @id @default(uuid())
  
  tokenAddress    String
  token           Token     @relation(fields: [tokenAddress], references: [address])
  
  holderAddress   String
  holderId        String?
  holder          User?     @relation(fields: [holderId], references: [id])
  
  balance         Decimal   @db.Decimal(28, 18)
  percentage      Decimal   @default(0) @db.Decimal(10, 4)
  firstBuyAt      DateTime?
  lastTradeAt     DateTime?
  totalBought     Decimal   @default(0) @db.Decimal(28, 18)
  totalSold       Decimal   @default(0) @db.Decimal(28, 18)
  realizedPnl     Decimal   @default(0) @db.Decimal(28, 18)
  
  updatedAt       DateTime  @updatedAt
  
  @@unique([tokenAddress, holderAddress])
  @@index([tokenAddress])
  @@index([holderAddress])
  @@map("token_holders")
}

model YieldClaim {
  id              String    @id @default(uuid())
  
  tokenAddress    String
  token           Token     @relation(fields: [tokenAddress], references: [address])
  
  claimerAddress  String
  claimerId       String?
  claimer         User?     @relation(fields: [claimerId], references: [id])
  
  amount          Decimal   @db.Decimal(28, 18)
  txHash          String    @unique
  blockNumber     Int
  timestamp       DateTime  @default(now())
  
  @@index([tokenAddress])
  @@index([claimerAddress])
  @@map("yield_claims")
}

model CreatorRating {
  id              String    @id @default(uuid())
  
  creatorAddress  String
  raterAddress    String
  raterId         String?
  rater           User?     @relation(fields: [raterId], references: [id])
  
  rating          Int
  txHash          String    @unique
  blockNumber     Int
  timestamp       DateTime  @default(now())
  
  @@unique([creatorAddress, raterAddress])
  @@index([creatorAddress])
  @@map("creator_ratings")
}

model SyncStatus {
  id              String    @id @default(uuid())
  contractName    String    @unique
  contractAddress String
  lastSyncedBlock Int       @default(0)
  lastSyncedAt    DateTime?
  isActive        Boolean   @default(true)
  
  @@map("sync_status")
}
