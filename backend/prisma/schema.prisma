// Prisma Schema for PrideConnect Platform

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// User model - Base user account
model User {
  id            String    @id @default(uuid())
  email         String    @unique
  username      String    @unique
  password      String
  firstName     String?
  lastName      String?
  displayName   String?
  birthDate     DateTime?
  genderIdentity String?
  orientation   String?
  avatar        String?
  bio           String?
  isVerified    Boolean   @default(false)
  isActive      Boolean   @default(true)
  role          UserRole  @default(USER)
  
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  // Relations
  creator       Creator?
  subscriptions Subscription[]
  orders        Order[]
  reviews       Review[]
  
  @@map("users")
}

enum UserRole {
  USER
  CREATOR
  ADMIN
}

// Creator model - Extended profile for content creators
model Creator {
  id              String    @id @default(uuid())
  userId          String    @unique
  displayName     String
  coverImage      String?
  description     String?
  
  // Verification & KYC
  isVerified      Boolean   @default(false)
  kycStatus       KYCStatus @default(PENDING)
  kycDocuments    Json?
  
  // Monetization
  subscriptionPrice Decimal @default(0) @db.Decimal(10, 2)
  earnings          Decimal @default(0) @db.Decimal(10, 2)
  
  // Social links
  socialLinks     Json?
  
  // Statistics
  followersCount  Int       @default(0)
  postsCount      Int       @default(0)
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  // Relations
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  posts           Post[]
  products        Product[]
  subscriptions   Subscription[]
  
  @@map("creators")
}

enum KYCStatus {
  PENDING
  APPROVED
  REJECTED
  RESUBMIT
}

// Post model - Content posts from creators
model Post {
  id          String      @id @default(uuid())
  creatorId   String
  title       String?
  content     String?
  mediaUrls   Json?       // Array of media URLs
  mediaType   MediaType   @default(IMAGE)
  isPublic    Boolean     @default(false) // false = subscribers only
  isPPV       Boolean     @default(false) // Pay-per-view
  ppvPrice    Decimal?    @db.Decimal(10, 2)
  
  // Engagement
  likesCount  Int         @default(0)
  commentsCount Int       @default(0)
  viewsCount  Int         @default(0)
  
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  
  // Relations
  creator     Creator     @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  
  @@map("posts")
}

enum MediaType {
  IMAGE
  VIDEO
  AUDIO
  DOCUMENT
}

// Subscription model - User subscriptions to creators
model Subscription {
  id              String    @id @default(uuid())
  userId          String
  creatorId       String
  
  status          SubscriptionStatus @default(ACTIVE)
  startDate       DateTime  @default(now())
  endDate         DateTime?
  autoRenew       Boolean   @default(true)
  
  // Payment
  amount          Decimal   @db.Decimal(10, 2)
  paymentMethod   String?
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  // Relations
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  creator         Creator   @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  
  @@unique([userId, creatorId])
  @@map("subscriptions")
}

enum SubscriptionStatus {
  ACTIVE
  EXPIRED
  CANCELLED
}

// Product model - Marketplace products
model Product {
  id              String    @id @default(uuid())
  creatorId       String
  
  name            String
  description     String
  category        ProductCategory
  type            ProductType
  
  // Pricing
  price           Decimal   @db.Decimal(10, 2)
  
  // Images
  images          Json?     // Array of image URLs
  
  // Inventory (for physical products)
  stock           Int?
  isUnlimited     Boolean   @default(false)
  
  // Digital product
  digitalFileUrl  String?
  
  // Status
  isActive        Boolean   @default(true)
  
  // Stats
  soldCount       Int       @default(0)
  viewsCount      Int       @default(0)
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  // Relations
  creator         Creator   @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  orderItems      OrderItem[]
  reviews         Review[]
  
  @@map("products")
}

enum ProductCategory {
  PHYSICAL_ITEM
  DIGITAL_CONTENT
  EXPERIENCE
  MERCHANDISE
  ART
  OTHER
}

enum ProductType {
  PHYSICAL
  DIGITAL
  HYBRID
}

// Order model - Marketplace orders
model Order {
  id              String      @id @default(uuid())
  userId          String
  orderNumber     String      @unique
  
  // Status
  status          OrderStatus @default(PENDING)
  
  // Pricing
  subtotal        Decimal     @db.Decimal(10, 2)
  shippingCost    Decimal     @default(0) @db.Decimal(10, 2)
  tax             Decimal     @default(0) @db.Decimal(10, 2)
  total           Decimal     @db.Decimal(10, 2)
  
  // Payment
  paymentStatus   PaymentStatus @default(PENDING)
  paymentMethod   String?
  transactionId   String?
  
  // Shipping
  shippingAddress Json?
  trackingNumber  String?
  
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  
  // Relations
  user            User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  items           OrderItem[]
  
  @@map("orders")
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
  REFUNDED
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

// OrderItem model - Items in an order
model OrderItem {
  id          String    @id @default(uuid())
  orderId     String
  productId   String
  
  quantity    Int       @default(1)
  price       Decimal   @db.Decimal(10, 2)
  
  createdAt   DateTime  @default(now())
  
  // Relations
  order       Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product     Product   @relation(fields: [productId], references: [id])
  
  @@map("order_items")
}

// Review model - Product reviews
model Review {
  id          String    @id @default(uuid())
  userId      String
  productId   String
  
  rating      Int       // 1-5
  comment     String?
  images      Json?     // Array of image URLs
  
  // Moderation
  isApproved  Boolean   @default(false)
  
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  
  // Relations
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  product     Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  
  @@unique([userId, productId])
  @@map("reviews")
}

model Chat {
  id         String    @id @default(uuid())
  type       ChatType
  creatorId  String?   // para DMs entre fã <-> creator
  liveId     String?   // para chats ligados a lives
  policy     DMPolicy? // usado para DMs
  permanent  Boolean   @default(false)
  participants ChatParticipant[]
  messages   Message[]
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
}

model ChatParticipant {
  id       String   @id @default(uuid())
  chatId   String
  userId   String
  joinedAt DateTime @default(now())
  lastSeen DateTime?
  chat     Chat     @relation(fields: [chatId], references: [id])
}

model Message {
  id            String       @id @default(uuid())
  chatId        String
  fromUserId    String
  type          MessageType  @default(TEXT)
  content       String?
  meta          Json?
  amount        Float?
  isHighlighted Boolean      @default(false)
  highlightUntil DateTime?
  messageState  MessageState @default(SENT)
  createdAt     DateTime     @default(now())
  deletedAt     DateTime?
  chat          Chat         @relation(fields: [chatId], references: [id])
}

model Live {
  id        String   @id @default(uuid())
  creatorId String
  config    Json?    // { mode, slowModeSeconds, tippersWindowMinutes, minTipToHighlight, requireAuthToChat, bannedWords: string[] }
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Tip {
  id         String   @id @default(uuid())
  fromUserId String
  toCreatorId String
  messageId  String?
  amount     Float
  currency   String   @default("BRL")
  status     String
  meta       Json?
  createdAt  DateTime @default(now())
}

enum ChatType {
  DIRECT      // DM 1×1 normal
  LIVE        // chat da live
  GROUP       // futuro (se quiseres)
}

enum DMPolicy {
  EVERYONE          // qualquer pessoa pode mandar DM
  TIPPED_ONLY       // só quem já deu tip alguma vez
  SUBSCRIBERS_ONLY  // só assinantes premium
  NO_ONE            // DMs bloqueados
}

enum MessageType {
  TEXT
  IMAGE
  VIDEO
  TIP
  GIFT
  SYSTEM            // ex: "Usuário entrou na live"
}

enum MessageState {
  SENT
  DELIVERED
  READ
  DELETED
  HIGHLIGHTED       // para tip messages na live
}