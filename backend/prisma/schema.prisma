// Prisma Schema for PrideConnect Platform

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// User model - Base user account
model User {
  id            String    @id @default(uuid())
  email         String    @unique
  username      String    @unique
  password      String
  firstName     String? 
  lastName      String?
  displayName   String?
  birthDate     DateTime?
  genderIdentity String?
  orientation   String?
  avatar        String?
  bio           String?
  isVerified    Boolean   @default(false)
  isActive      Boolean   @default(true)
  role          UserRole  @default(USER)
  
  payments      Payment[] @relation("UserPayments")
  wallet        UserWallet? 

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  // Relations originais
  creator       Creator?  
  subscriptions Subscription[]
  orders        Order[]
  reviews       Review[]
  
  // Relações de mensagens
  creatorConversations     Conversation[] @relation("CreatorConversations")
  subscriberConversations  Conversation[] @relation("SubscriberConversations")
  sentMessages             Message[]      @relation("SentMessages")
  receivedMessages         Message[]      @relation("ReceivedMessages")
  
  @@map("users")
}

enum UserRole {
  USER
  CREATOR
  ADMIN
}

// Creator model - Extended profile for content creators
model Creator {
  id              String    @id @default(uuid())
  userId          String    @unique
  displayName     String
  coverImage      String?
  description     String?
  
  // Verification & KYC
  isVerified      Boolean   @default(false)
  kycStatus       KYCStatus @default(PENDING)
  kycDocuments    Json? 
  
  // Monetization
  subscriptionPrice Decimal @default(0) @db.Decimal(10, 2)
  earnings          Decimal @default(0) @db.Decimal(10, 2)
  
  // Settings fields
  location              String?
  website               String?
  category              String?
  socialLinks           Json?
  
  // Subscription settings
  discounts             Json?           @default("{\"threeMonths\": 10, \"sixMonths\": 15, \"twelveMonths\": 20}")
  promoActive           Boolean         @default(false)
  promoDiscount         Int?
  promoDuration         Int?
  promoExpiry           String?
  trialEnabled          Boolean         @default(false)
  trialDays             Int?
  
  // Payment settings
  withdrawMethod        String          @default("pix")
  pixType               String?
  pixKey                String?
  cryptoWallets         Json?
  autoWithdraw          Boolean         @default(false)
  autoWithdrawMin       Int             @default(100)
  
  // Notification settings
  emailNotifications    Json?
  pushNotifications     Json?
  marketingEmails       Boolean         @default(true)
  newsletter            Boolean         @default(true)
  
  // Privacy settings
  publicProfile         Boolean         @default(true)
  showActivity          Boolean         @default(true)
  showSubscriberCount   Boolean         @default(true)
  messagePermission     String          @default("subscribers")
  allowTips             Boolean         @default(true)
  watermark             Boolean         @default(true)
  disableScreenshots    Boolean         @default(false)
  hideFromSearch        Boolean         @default(false)
  blockedCountries      String[]        @default([])
  
  // Content settings
  defaultPPV            Boolean         @default(false)
  autoPublish           Boolean         @default(true)
  commentsEnabled       Boolean         @default(true)
  defaultPPVPrice       Float           @default(9.99)
  imageQuality          String          @default("high")
  videoQuality          String          @default("1080p")
  
  // Blocking
  blockedUsers          String[]        @default([])
  blockedWords          String[]        @default([])
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  // Relations
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  posts           Post[]
  products        Product[]
  subscriptions   Subscription[]

  receivedPayments  Payment[]   @relation("CreatorPayments")
  balance           CreatorBalance? 
  withdrawals       Withdrawal[]
  
  @@map("creators")
}

enum KYCStatus {
  PENDING
  APPROVED
  REJECTED
  RESUBMIT
}

// Post model - Content posts from creators
model Post {
  id          String      @id @default(uuid())
  creatorId   String
  title       String? 
  content     String?
  mediaUrls   Json?       // Array of media URLs
  mediaType   MediaType   @default(IMAGE)
  isPublic    Boolean     @default(false) // false = subscribers only
  isPPV       Boolean     @default(false) // Pay-per-view
  ppvPrice    Decimal?     @db.Decimal(10, 2)
  
  // Engagement
  likesCount  Int         @default(0)
  commentsCount Int       @default(0)
  viewsCount  Int         @default(0)
  
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  
  // Relations
  creator     Creator     @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  
  @@map("posts")
}

enum MediaType {
  IMAGE
  VIDEO
  AUDIO
  DOCUMENT
}

// Subscription model - User subscriptions to creators
model Subscription {
  id              String    @id @default(uuid())
  userId          String
  creatorId       String
  
  status          SubscriptionStatus @default(ACTIVE)
  startDate       DateTime  @default(now())
  endDate         DateTime?
  autoRenew       Boolean   @default(true)
  
  // Payment
  amount          Decimal   @db.Decimal(10, 2)
  paymentMethod   String?
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  // Relations
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  creator         Creator   @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  
  @@unique([userId, creatorId])
  @@map("subscriptions")
}

enum SubscriptionStatus {
  ACTIVE
  EXPIRED
  CANCELLED
}

// Product model - Marketplace products
model Product {
  id              String    @id @default(uuid())
  creatorId       String
  
  name            String
  description     String
  category        ProductCategory
  type            ProductType
  
  // Pricing
  price           Decimal   @db.Decimal(10, 2)
  
  // Images
  images          Json?     // Array of image URLs
  
  // Inventory (for physical products)
  stock           Int? 
  isUnlimited     Boolean   @default(false)
  
  // Digital product
  digitalFileUrl  String?
  
  // Status
  isActive        Boolean   @default(true)
  
  // Stats
  soldCount       Int       @default(0)
  viewsCount      Int       @default(0)
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  // Relations
  creator         Creator   @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  orderItems      OrderItem[]
  reviews         Review[]
  
  @@map("products")
}

enum ProductCategory {
  PHYSICAL_ITEM
  DIGITAL_CONTENT
  EXPERIENCE
  MERCHANDISE
  ART
  OTHER
}

enum ProductType {
  PHYSICAL
  DIGITAL
  HYBRID
}

// Order model - Marketplace orders
model Order {
  id              String      @id @default(uuid())
  userId          String
  orderNumber     String      @unique
  
  // Status
  status          OrderStatus @default(PENDING)
  
  // Pricing
  subtotal        Decimal     @db.Decimal(10, 2)
  shippingCost    Decimal     @default(0) @db.Decimal(10, 2)
  tax             Decimal     @default(0) @db.Decimal(10, 2)
  total           Decimal     @db.Decimal(10, 2)
  
  // Payment - ⚠️ RENOMEADO para OrderPaymentStatus
  paymentStatus   OrderPaymentStatus @default(ORDER_PENDING)
  paymentMethod   String?
  transactionId   String?
  
  // Shipping
  shippingAddress Json?
  trackingNumber  String?
  
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  
  // Relations
  user            User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  items           OrderItem[]
  
  @@map("orders")
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
  REFUNDED
}

// ⚠️ ENUM RENOMEADO para evitar conflito com PaymentStatus
enum OrderPaymentStatus {
  ORDER_PENDING
  ORDER_COMPLETED
  ORDER_FAILED
  ORDER_REFUNDED
}

// OrderItem model - Items in an order
model OrderItem {
  id          String    @id @default(uuid())
  orderId     String
  productId   String
  
  quantity    Int       @default(1)
  price       Decimal   @db.Decimal(10, 2)
  
  createdAt   DateTime  @default(now())
  
  // Relations
  order       Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product     Product   @relation(fields: [productId], references: [id])
  
  @@map("order_items")
}

// Review model - Product reviews
model Review {
  id          String    @id @default(uuid())
  userId      String
  productId   String
  
  rating      Int       // 1-5
  comment     String?
  images      Json?     // Array of image URLs
  
  // Moderation
  isApproved  Boolean   @default(false)
  
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  
  // Relations
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  product     Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  
  @@unique([userId, productId])
  @@map("reviews")
}

// ============================================
// SISTEMA DE MENSAGENS
// ============================================

model Conversation {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Participantes
  creatorId    String
  creator      User   @relation("CreatorConversations", fields: [creatorId], references: [id], onDelete: Cascade)
  
  subscriberId String
  subscriber   User   @relation("SubscriberConversations", fields: [subscriberId], references: [id], onDelete: Cascade)

  // Última mensagem
  lastMessageText      String?
  lastMessageSenderId  String?
  lastMessageTimestamp DateTime?

  // Contadores de não lidas
  unreadCountCreator    Int @default(0)
  unreadCountSubscriber Int @default(0)

  // Status
  status String @default("active") // active, archived, blocked
  isVIP  Boolean @default(false)

  // Relações
  messages Message[]

  @@unique([creatorId, subscriberId])
  @@index([creatorId, status])
  @@index([subscriberId, status])
  @@index([lastMessageTimestamp])
  @@map("conversations")
}

model Message {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relação com conversa
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  // Remetente e destinatário
  senderId    String
  sender      User   @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)
  
  recipientId String
  recipient   User   @relation("ReceivedMessages", fields: [recipientId], references: [id], onDelete: Cascade)

  // Tipo e conteúdo
  type String @default("text") // text, image, video, paid

  // Conteúdo
  contentText     String?
  contentMediaUrl String[] // Array de URLs
  contentPrice    Float?
  contentIsPaid   Boolean  @default(false)

  // Status
  status String @default("sent") // sent, delivered, read, failed
  readAt DateTime?

  // Metadados
  metadataIpAddress       String?
  metadataUserAgent       String?
  metadataFlagged         Boolean @default(false)
  metadataModerationAction String?  

  deletedAt DateTime?

  @@index([conversationId, createdAt])
  @@index([senderId, createdAt])
  @@index([status])
  @@map("messages")
}

// ============================================
// SISTEMA DE PAGAMENTOS
// ============================================

model Payment {
  id              String        @id @default(uuid())
  
  // Relacionamentos
  userId          String
  user            User          @relation("UserPayments", fields: [userId], references: [id], onDelete: Cascade)
  
  creatorId       String?  
  creator         Creator?      @relation("CreatorPayments", fields: [creatorId], references: [id])
  
  // Tipo de pagamento
  type            PaymentType
  
  // Referências
  subscriptionId  String?
  postId          String?
  messageId       String?
  
  // Valores em FIAT
  amountUSD       Decimal       @db.Decimal(10, 2)
  amountBRL       Decimal?        @db.Decimal(10, 2)
  currency        String        @default("USD")
  
  // Valores em Cripto
  cryptoCurrency  String?         // BTC, ETH, USDT_TRC20, etc
  cryptoAmount    String?       // Quantidade exata em cripto
  cryptoAddress   String?       // Endereço de recebimento gerado
  expectedAmount  String?       // Quantidade esperada
  actuallyPaid    String?       // Quantidade realmente paga
  
  // Blockchain
  txHash          String?       // Transaction hash
  confirmations   Int           @default(0)
  networkFee      String?       // Taxa de rede paga
  
  // Status
  status          PaymentStatus @default(PENDING)
  
  // Gateway usado
  gateway         PaymentGateway
  gatewayOrderId  String?       @unique // ID externo do gateway
  gatewayData     Json?         // Dados extras do gateway
  
  // Taxas da plataforma
  platformFee     Decimal       @db.Decimal(10, 2) @default(0) // 10%
  gatewayFee      Decimal       @db.Decimal(10, 2) @default(0) // Taxa do gateway
  netAmount       Decimal       @db.Decimal(10, 2) // Valor líquido para o criador
  
  // Timestamps
  paidAt          DateTime?  
  confirmedAt     DateTime?
  expiresAt       DateTime?
  
  // Metadados
  ipAddress       String?
  userAgent       String?
  metadata        Json?
  
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  
  @@index([userId])
  @@index([creatorId])
  @@index([status])
  @@index([gateway])
  @@index([txHash])
  @@index([gatewayOrderId])
  @@index([type])
  @@map("payments")
}

model CreatorBalance {
  id              String        @id @default(uuid())
  creatorId       String        @unique
  creator         Creator       @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  
  // Saldo disponível
  availableUSD    Decimal       @db.Decimal(10, 2) @default(0)
  
  // Saldo pendente (aguardando confirmação)
  pendingUSD      Decimal       @db.Decimal(10, 2) @default(0)
  
  // Total de ganhos
  lifetimeEarnings Decimal      @db.Decimal(10, 2) @default(0)
  
  // Saques
  totalWithdrawn  Decimal       @db.Decimal(10, 2) @default(0)
  
  // Estatísticas
  lastPaymentAt   DateTime?
  lastWithdrawalAt DateTime?
  
  updatedAt       DateTime      @updatedAt
  
  @@map("creator_balances")
}

model Withdrawal {
  id              String           @id @default(uuid())
  creatorId       String
  creator         Creator          @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  
  // Valores
  amountUSD       Decimal          @db.Decimal(10, 2)
  
  // Destino Cripto
  cryptoCurrency  String           // BTC, ETH, USDT_TRC20, etc
  cryptoAmount    String
  destinationAddress String
  
  // Blockchain
  txHash          String?
  networkFee      Decimal?           @db.Decimal(10, 2)
  
  // Status
  status          WithdrawalStatus @default(PENDING)
  
  // Taxas
  platformFee     Decimal          @db.Decimal(10, 2) @default(2) // Taxa fixa $2
  netAmount       Decimal          @db.Decimal(10, 2) // Valor líquido enviado
  
  // Gateway
  gateway         PaymentGateway? 
  gatewayTxId     String? 
  
  // Aprovação (se necessário)
  approvedBy      String?
  approvedAt      DateTime?
  rejectedReason  String? 
  
  // Timestamps
  processedAt     DateTime? 
  completedAt     DateTime? 
  
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  
  @@index([creatorId])
  @@index([status])
  @@map("withdrawals")
}

model UserWallet {
  id              String        @id @default(uuid())
  userId          String        @unique
  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  // Saldo depositado (sistema de carteira interna)
  balanceUSD      Decimal       @db.Decimal(10, 2) @default(0)
  
  // Histórico
  totalDeposited  Decimal       @db.Decimal(10, 2) @default(0)
  totalSpent      Decimal       @db.Decimal(10, 2) @default(0)
  
  // Auto-renovação
  autoRenewEnabled Boolean      @default(false)
  lowBalanceAlert  Boolean      @default(true)
  alertThreshold   Decimal      @db.Decimal(10, 2) @default(20)
  
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  
  @@map("user_wallets")
}

// Enums
enum PaymentType {
  SUBSCRIPTION
  SUBSCRIPTION_RENEWAL
  PPV_MESSAGE
  PPV_POST
  TIP
  WALLET_DEPOSIT
  GIFT
}

enum PaymentStatus {
  PENDING          // Aguardando pagamento
  WAITING          // Pagamento detectado, aguardando confirmações
  CONFIRMING       // Confirmando no blockchain
  COMPLETED        // Confirmado e processado
  FAILED           // Falhou
  EXPIRED          // Expirou (15 min)
  PARTIALLY_PAID   // Pagou menos que o esperado
  REFUNDED         // Reembolsado
  CANCELLED        // Cancelado pelo usuário
}

enum PaymentGateway {
  NOWPAYMENTS      // API externa (fácil)
  BTCPAY           // Self-hosted (economia)
  COINPAYMENTS     // Alternativa
  PIX              // Brasil
  STRIPE           // Cartão
  MANUAL           // Transferência manual
}

enum WithdrawalStatus {
  PENDING          // Solicitado
  APPROVED         // Aprovado (se necessário)
  PROCESSING       // Processando
  COMPLETED        // Enviado
  FAILED           // Falhou
  CANCELLED        // Cancelado
  REJECTED         // Rejeitado (fraude)
}