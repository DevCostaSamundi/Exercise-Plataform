# Docker Environment Configuration Example
# Copy this file to .env and update with your values

# PostgreSQL Configuration
POSTGRES_PASSWORD=devpassword123

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-this-in-production

# Database URL (for backend service)
DATABASE_URL=postgresql://exercise_user:devpassword123@postgres:5432/exercise_platform?schema=public

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# Redis URL
REDIS_URL=redis://redis:6379

# Cloudinary Configuration (optional - for file uploads)
# If not set, files will be saved locally in uploads/
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Email Configuration (optional - for production)
# In development, emails are logged but not sent
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASSWORD=
EMAIL_FROM=noreply@example.com

# Node Environment
NODE_ENV=development

# API Version
API_VERSION=v1

# Server Port
PORT=5000
