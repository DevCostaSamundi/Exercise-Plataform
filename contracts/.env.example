# =================================
# LAUNCHPAD 2.0 - BASE NETWORK
# =================================

# Base Sepolia (Testnet) - Para desenvolvimento
BASE_SEPOLIA_RPC=https://sepolia.base.org
BASE_SEPOLIA_PRIVATE_KEY=your_testnet_private_key_here

# Base Mainnet (Produção) - Para deploy final
BASE_MAINNET_RPC=https://mainnet.base.org
BASE_MAINNET_PRIVATE_KEY=your_mainnet_private_key_here

# BaseScan API Key - Para verificação de contratos
# Obtenha em: https://basescan.org/register
BASESCAN_API_KEY=your_basescan_api_key_here

# Platform wallet address (receives fees)
PLATFORM_WALLET_ADDRESS=0x...

# =================================
# OPTIONAL: RPC PROVIDERS PREMIUM
# =================================

# Alchemy (Recomendado) - Melhor performance
# Cadastre-se em: https://www.alchemy.com
# BASE_SEPOLIA_RPC=https://base-sepolia.g.alchemy.com/v2/YOUR_API_KEY
# BASE_MAINNET_RPC=https://base-mainnet.g.alchemy.com/v2/YOUR_API_KEY

# =================================
# PRIDECONNECT (ARCHIVED - REFERÊNCIA)
# =================================

# Deployer wallet private key (NEVER commit this!)
# DEPLOYER_PRIVATE_KEY=your_private_key_here

# RPC URLs
# POLYGON_RPC_URL=https://polygon-mainnet.g.alchemy.com/v2/YOUR_ALCHEMY_KEY
# MUMBAI_RPC_URL=https://polygon-mumbai.g.alchemy.com/v2/YOUR_ALCHEMY_KEY

# Polygonscan API Key (for contract verification)
# POLYGONSCAN_API_KEY=your_polygonscan_api_key

# USDC Contract Addresses (Polygon - archived)
# USDC_ADDRESS_POLYGON=0x2791Bca1f2de4661ED88A30C99A7a9449Aa84174
# USDC_ADDRESS_MUMBAI=0x0FA8781a83E46826621b3BC094Ea2A0212e71B23

# =================================
# INSTRUÇÕES
# =================================

# 1. Copie este arquivo para .env (git-ignored)
# 2. Preencha suas private keys (NUNCA commite .env!)
# 3. Para testnet: use wallet separada com pouco ETH
# 4. Para mainnet: USE HARDWARE WALLET se possível
# 5. Obtenha testnet ETH: https://www.coinbase.com/faucets
# 6. Obtenha BaseScan API: https://basescan.org/register
