# -----------------------------------------------------------------------------
# API CONFIGURATION
# -----------------------------------------------------------------------------
VITE_API_URL=http://localhost:5000
VITE_FRONTEND_URL=http://localhost:5173

# -----------------------------------------------------------------------------
# WEB3AUTH CONFIGURATION
# -----------------------------------------------------------------------------
# Get your Client ID from: https://dashboard.web3auth.io
VITE_WEB3AUTH_CLIENT_ID=BPi5PB_UiIZ-cPz1GtV5i1I2iOSOHuimiXBI0e-Oe_u6X3oVAbCiAZOTEBtTXw4tsluTITPqA8zMsfxIKMjiqNQ

# Web3Auth Network: 'sapphire_mainnet', 'sapphire_devnet', 'testnet', 'cyan', 'aqua'
VITE_WEB3AUTH_NETWORK=sapphire_devnet

# -----------------------------------------------------------------------------
# BLOCKCHAIN CONFIGURATION
# -----------------------------------------------------------------------------
# Network: 'polygon' for mainnet, 'polygon-amoy' for testnet
VITE_NETWORK=polygon-amoy

# Chain ID
# Polygon Mainnet: 137 (0x89)
# Polygon Amoy Testnet: 80002 (0x13882)
VITE_CHAIN_ID=80002

# RPC URL - IMPORTANT: Replace with your Alchemy key
# Get free key from: https://dashboard.alchemy.com
VITE_RPC_URL=https://polygon-amoy.g.alchemy.com/v2/YOUR_ALCHEMY_KEY_HERE

# Alternative free RPC (if you don't have Alchemy yet)
# VITE_RPC_URL=https://polygon-amoy-bor-rpc.publicnode.com

# Block Explorer URL
VITE_EXPLORER_URL=https://amoy.polygonscan.com

# -----------------------------------------------------------------------------
# SMART CONTRACT ADDRESSES
# -----------------------------------------------------------------------------
# USDC Token Contract Address
# Polygon Mainnet USDC: 0x3c499c542cEF5E3811e1192ce70d8cC03d5c3359
# Polygon Amoy USDC (testnet - mock): 0x41E94Eb019C0762f9Bfcf9Fb1E58725BfB0e7582
VITE_USDC_ADDRESS=0x41E94Eb019C0762f9Bfcf9Fb1E58725BfB0e7582

# Payment Receiver Address (your backend wallet address)
VITE_PAYMENT_RECEIVER_ADDRESS=0x0000000000000000000000000000000000000000

# -----------------------------------------------------------------------------
# ALCHEMY CONFIGURATION (Optional - for enhanced features)
# -----------------------------------------------------------------------------
# Alchemy API Key (from https://dashboard.alchemy.com)
VITE_ALCHEMY_API_KEY=YOUR_ALCHEMY_KEY_HERE

# Alchemy Webhook ID (for payment notifications)
VITE_ALCHEMY_WEBHOOK_ID=YOUR_WEBHOOK_ID_HERE

# -----------------------------------------------------------------------------
# FEATURE FLAGS
# -----------------------------------------------------------------------------
VITE_ENABLE_WEB3AUTH=true
VITE_ENABLE_CRYPTO_PAYMENTS=true
VITE_ENABLE_BALANCE_PAYMENTS=true
VITE_ENABLE_NOTIFICATIONS=true

# -----------------------------------------------------------------------------
# UI CONFIGURATION
# -----------------------------------------------------------------------------
VITE_APP_NAME=PrideConnect
VITE_APP_DESCRIPTION=Web3 Powered Content Platform
VITE_PRIMARY_COLOR=#9333ea

# -----------------------------------------------------------------------------
# PAYMENT CONFIGURATION
# -----------------------------------------------------------------------------
# Minimum deposit amount (USD)
VITE_MIN_DEPOSIT=10

# Maximum deposit amount (USD)
VITE_MAX_DEPOSIT=10000

# Platform fee percentage (0.10 = 10%)
VITE_PLATFORM_FEE=0.10

# -----------------------------------------------------------------------------
# DEVELOPMENT CONFIGURATION
# -----------------------------------------------------------------------------
VITE_DEV_MODE=true
VITE_DEBUG=true

# Mock payments (for testing without real blockchain)
VITE_MOCK_PAYMENTS=false