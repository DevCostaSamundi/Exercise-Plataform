# -----------------------------------------------------------------------------
# API CONFIGURATION
# -----------------------------------------------------------------------------
VITE_API_URL=http://localhost:5000/api/v1
VITE_SOCKET_URL=http://localhost:5000
VITE_FRONTEND_URL=http://localhost:5173

# -----------------------------------------------------------------------------
# WEB3AUTH CONFIGURATION
# -----------------------------------------------------------------------------
# Get your Client ID from: https://dashboard.web3auth.io
VITE_WEB3AUTH_CLIENT_ID=BPi5PB_UiIZ-cPz1GtV5i1I2iOSOHuimiXBI0e-Oe_u6X3oVAbCiAZOTEBtTXw4tsluTITPqA8zMsfxIKMjiqNQ

# Web3Auth Network: 'sapphire_mainnet', 'sapphire_devnet', 'testnet', 'cyan', 'aqua'
VITE_WEB3AUTH_NETWORK=sapphire_mainnet

# Admin wallet address (owner of contracts)
VITE_OWNER_ADDRESS=0x0000000000000000000000000000000000000000

# -----------------------------------------------------------------------------
# BASE NETWORK CONFIGURATION
# -----------------------------------------------------------------------------
# Network: 'base' for mainnet, 'base-sepolia' for testnet
VITE_NETWORK=base-sepolia

# Chain ID
# Base Mainnet: 8453 (0x2105)
# Base Sepolia Testnet: 84532 (0x14a34)
VITE_CHAIN_ID=84532

# RPC URLs
# Base Sepolia Testnet (free)
VITE_BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
# Base Mainnet (free)
VITE_BASE_RPC_URL=https://mainnet.base.org

# Alternative RPC with Alchemy (optional, for enhanced features)
# Get free key from: https://dashboard.alchemy.com
# VITE_BASE_SEPOLIA_RPC_URL=https://base-sepolia.g.alchemy.com/v2/YOUR_ALCHEMY_KEY_HERE
# VITE_BASE_RPC_URL=https://base-mainnet.g.alchemy.com/v2/YOUR_ALCHEMY_KEY_HERE

# Block Explorer URL
VITE_EXPLORER_URL=https://sepolia.basescan.org

# -----------------------------------------------------------------------------
# LAUNCHPAD 2.0 SMART CONTRACT ADDRESSES
# -----------------------------------------------------------------------------
# TokenFactory Contract (deployed on Base Sepolia)
VITE_TOKEN_FACTORY_ADDRESS=0x0000000000000000000000000000000000000000

# BondingCurve Contract
VITE_BONDING_CURVE_ADDRESS=0x0000000000000000000000000000000000000000

# LiquidityLocker Contract
VITE_LIQUIDITY_LOCKER_ADDRESS=0x0000000000000000000000000000000000000000

# YieldDistributor Contract
VITE_YIELD_DISTRIBUTOR_ADDRESS=0x0000000000000000000000000000000000000000

# CreatorRegistry Contract
VITE_CREATOR_REGISTRY_ADDRESS=0x0000000000000000000000000000000000000000

# FeeCollector Contract
VITE_FEE_COLLECTOR_ADDRESS=0x0000000000000000000000000000000000000000

# -----------------------------------------------------------------------------
# WALLETCONNECT CONFIGURATION
# -----------------------------------------------------------------------------
# Alchemy API Key (from https://dashboard.alchemy.com)
VITE_ALCHEMY_API_KEY=YOUR_ALCHEMY_KEY_HERE

# Alchemy Webhook ID (for payment notifications)
VITE_ALCHEMY_WEBHOOK_ID=YOUR_WEBHOOK_ID_HERE

# -----------------------------------------------------------------------------
# FEATURE FLAGS
# -----------------------------------------------------------------------------
VITE_ENABLE_WEB3AUTH=true
VITE_ENABLE_CRYPTO_PAYMENTS=true
VITE_ENABLE_BALANCE_PAYMENTS=true
VITE_ENABLE_NOTIFICATIONS=true

# -----------------------------------------------------------------------------
# UI CONFIGURATION
# -----------------------------------------------------------------------------
VITE_APP_NAME=PrideConnect
VITE_APP_DESCRIPTION=Web3 Powered Content Platform
VITE_PRIMARY_COLOR=#9333ea

# -----------------------------------------------------------------------------
# PAYMENT CONFIGURATION
# -----------------------------------------------------------------------------
# Minimum deposit amount (USD)
VITE_MIN_DEPOSIT=10

# Maximum deposit amount (USD)
VITE_MAX_DEPOSIT=10000

# Platform fee percentage (0.10 = 10%)
VITE_PLATFORM_FEE=0.10

# -----------------------------------------------------------------------------
# DEVELOPMENT CONFIGURATION
# -----------------------------------------------------------------------------
VITE_DEV_MODE=true
VITE_DEBUG=true

# Mock payments (for testing without real blockchain)
VITE_MOCK_PAYMENTS=false