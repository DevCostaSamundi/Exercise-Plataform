# ========================================
# PrideConnect - Environment Configuration
# ========================================

# API Configuration
# -----------------
# Base URL for the backend API (without /api/v1 - will be added automatically)
# Local development: http://localhost:5000
# Production: https://your-production-api.com
VITE_API_URL=http://localhost:5000

# API Version - defaults to v1 if not specified
VITE_API_VERSION=v1

# Application Configuration
# -------------------------
VITE_APP_NAME=PrideConnect
VITE_APP_VERSION=1.0.0

# Environment
# -----------
# Options: development, production
VITE_NODE_ENV=development

# Logging
# -------
# Enable detailed API logging in console (true/false)
# Recommended: true for development, false for production
VITE_ENABLE_LOGGING=true

# Features
# --------
# Enable/disable specific features
VITE_ENABLE_NOTIFICATIONS=true
VITE_ENABLE_MESSAGING=true
VITE_ENABLE_ANALYTICS=true
